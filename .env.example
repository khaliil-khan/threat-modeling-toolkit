# =============================================================================
# Threat Toolkit — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# REQUIRED IN PRODUCTION
# -----------------------------------------------------------------------------

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-very-long-random-secret-key-here

# Set to 'production' on your EC2/server
APP_ENV=production

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Option 1: Local PostgreSQL (via docker-compose with db service)
DATABASE_URL=postgresql://threats_user:threats_pass@db:5432/threats_db

# Option 2: AWS RDS PostgreSQL
# DATABASE_URL=postgresql://admin:YourPassword@your-instance.xxxx.us-east-1.rds.amazonaws.com:5432/threats_db

# Option 3: SQLite (development only, NOT recommended for production)
# DATABASE_URL=sqlite:///threats.db

# Local PostgreSQL container credentials (used by docker-compose db service)
DB_USER=threats_user
DB_PASSWORD=threats_pass
DB_NAME=threats_db
DB_PORT=5432

# -----------------------------------------------------------------------------
# EMAIL (Password Reset)
# -----------------------------------------------------------------------------

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# ADMIN
# -----------------------------------------------------------------------------

# Comma-separated emails that get admin role on registration
ADMIN_EMAILS=kh.khalil2599@gmail.com

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------

PORT=5000
FLASK_DEBUG=false

# =============================================================================
# DEPLOYMENT GUIDE
# =============================================================================
#
# --- Option A: EC2 with local PostgreSQL (docker-compose) ---
#
#   1. SSH into your EC2 instance
#   2. Clone your repo
#   3. cp .env.example .env && nano .env  (fill in values)
#   4. docker-compose up -d
#   5. Both app + PostgreSQL run in containers
#
# --- Option B: EC2 with AWS RDS ---
#
#   1. Create an RDS PostgreSQL instance in AWS Console
#   2. Note the endpoint (e.g., mydb.xxxx.us-east-1.rds.amazonaws.com)
#   3. Set DATABASE_URL in .env:
#      DATABASE_URL=postgresql://admin:password@mydb.xxxx.us-east-1.rds.amazonaws.com:5432/threats_db
#   4. Run: docker-compose -f docker-compose.rds.yml up -d
#
# --- Migrating existing SQLite data to PostgreSQL ---
#
#   1. Set DATABASE_URL to your PostgreSQL instance
#   2. Run: python migrate_to_postgres.py
#   3. Verify data in PostgreSQL
#
# =============================================================================
